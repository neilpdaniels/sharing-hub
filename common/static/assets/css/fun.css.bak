/*
 * fun.css — site-wide friendly styling layer
 * Sits on top of main.css and uses the site header teal/slate palette
 * but softens edges, adds warmth and personality.
 */

/* ─── Global warmth ─────────────────────────────────────────── */

body {
    background-color: #e9f1f3;
}

/* Keep header/search bars stable and matched */
#site-header.fixed {
    background-color: #1d7d97;
}

#site-header #site-search-bar {
    background-color: #1d7d97;
}

#site-header.sticky {
    background-color: #3c4556;
}

#site-header.sticky #site-search-bar {
    background-color: #3c4556;
}

/* Match main banner with non-sticky header tone */
.page-header {
    background-color: #1d7d97;
}

/* Make title banner less tall/deep */
.page-header-style--1 {
    padding: 0 0 12px;
}

.page-subtitle:empty {
    display: none;
}

.page-title {
    margin: 0;
    font-size: 32px;
    line-height: 1.15;
}

/* Rounder headings */
h1, h2, h3, h4, h5, h6,
.h1, .h2, .h3, .h4, .h5, .h6 {
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    letter-spacing: -0.01em;
}

h1,
.h1 {
    margin-bottom: 0 !important;
}

/* ─── Rounded, friendly buttons ─────────────────────────────── */

.btn {
    border-radius: 10px !important;
    font-weight: 700;
    font-family: 'Nunito', sans-serif;
    letter-spacing: .01em;
    transition: transform .15s, box-shadow .15s, opacity .15s;
}

.btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0,0,0,.13);
}

.btn:active {
    transform: translateY(0);
}

.btn-primary {
    background: #1d7d97;
    border-color: #1d7d97;
    box-shadow: 0 3px 10px rgba(29,125,151,.28);
}

.btn-primary:hover,
.btn-primary:focus {
    background: #3c4556;
    border-color: #3c4556;
    box-shadow: 0 5px 18px rgba(60,69,86,.35);
}

.btn-secondary {
    background: #e9f1f3;
    border-color: #c7d7dc;
    color: #47515a;
}

.btn-secondary:hover {
    background: #d9e8ec;
    border-color: #9fb8c0;
    color: #212529;
}

/* ─── Rounded form controls ─────────────────────────────────── */

.form-control {
    border-radius: 10px !important;
    border: 1.5px solid #c7d7dc;
    background: #fafbff;
    transition: border-color .2s, box-shadow .2s;
}

.form-control:focus {
    border-color: #1d7d97;
    box-shadow: 0 0 0 3px rgba(29,125,151,.14);
    background: #fff;
}

.input-group-text {
    border-radius: 10px 0 0 10px !important;
    border: 1.5px solid #c7d7dc;
    border-right: none;
    background: #e9f1f3;
    color: #5f7681;
    font-weight: 700;
}

.input-group .form-control {
    border-radius: 0 10px 10px 0 !important;
}

/* ─── Cards & panels ─────────────────────────────────────────── */

.card {
    border-radius: 16px !important;
    border: none !important;
    box-shadow: 0 4px 20px rgba(0,0,0,.07);
}

.card-header {
    border-radius: 16px 16px 0 0 !important;
    background: #fff;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    border-bottom: 1.5px solid #dce6ea;
}

/* ─── Centred auth-page card ─────────────────────────────────── */

.sh-auth-wrap {
    min-height: calc(100vh - 130px);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 7rem 1rem 3rem;
}

@media (max-width: 767px) {
    .sh-auth-wrap {
        min-height: auto;
        padding: 5.5rem .75rem 2rem;
    }
}

.sh-auth-card {
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 8px 36px rgba(29,125,151,.14);
    overflow: hidden;
    max-width: 480px;
    width: 100%;
}

.sh-auth-header {
    background: #1d7d97;
    padding: 2rem 2rem 1.6rem;
    text-align: center;
    color: #fff;
}

.sh-auth-header .sh-emoji {
    font-size: 2.8rem;
    line-height: 1;
    display: block;
    margin-bottom: .4rem;
}

.sh-auth-header h1 {
    font-family: 'Nunito', sans-serif;
    font-size: 1.55rem;
    font-weight: 900;
    margin: 0 0 .25rem;
    color: #fff;
}

.sh-auth-header p {
    font-size: .92rem;
    opacity: .88;
    margin: 0;
}

.sh-auth-body {
    padding: 1.6rem 2rem 2rem;
}

.sh-auth-body .form-control {
    border-radius: 10px !important;
    border: 1.5px solid #c7d7dc;
    background: #fafbff;
}

.sh-auth-body .form-control:focus {
    border-color: #1d7d97;
    box-shadow: 0 0 0 3px rgba(29,125,151,.14);
    background: #fff;
}

.sh-auth-body .input-group-text {
    border-radius: 10px 0 0 10px !important;
    border: 1.5px solid #c7d7dc;
    border-right: none;
    background: #e9f1f3;
    color: #5f7681;
    font-weight: 700;
}

.sh-auth-body .input-group .form-control {
    border-radius: 0 10px 10px 0 !important;
}

/* Full-width CTA button */
.sh-btn-cta {
    display: block;
    width: 100%;
    padding: .85rem;
    border: none;
    border-radius: 12px;
    background: #1d7d97;
    color: #fff;
    font-family: 'Nunito', sans-serif;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: .02em;
    cursor: pointer;
    margin-top: 1.4rem;
    transition: background .2s, transform .15s, box-shadow .15s;
    box-shadow: 0 4px 14px rgba(29,125,151,.30);
    text-align: center;
}

.sh-btn-cta:hover {
    background: #3c4556;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(60,69,86,.36);
    color: #fff;
    text-decoration: none;
}

.sh-btn-cta:active {
    transform: translateY(0);
}

/* Section sub-labels inside auth cards */
.sh-field-label {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #6f8791;
    margin: 1.1rem 0 .4rem;
}

/* Step tracker */
.sh-steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 1rem 2rem .2rem;
    gap: 0;
}

.sh-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
}

.sh-step-dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: .82rem;
    transition: all .3s;
}

.sh-step.active .sh-step-dot { background: #1d7d97; color: #fff; box-shadow: 0 3px 12px rgba(29,125,151,.34); }
.sh-step.done .sh-step-dot   { background: #e3f6e8; color: #2e9650; }
.sh-step.waiting .sh-step-dot{ background: #dce6ea; color: #8aa0a8; }

.sh-step-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: #8aa0a8;
}
.sh-step.active .sh-step-label  { color: #1d7d97; }
.sh-step.done .sh-step-label    { color: #2e9650; }

.sh-step-line {
    flex: 1;
    height: 2px;
    background: #dce6ea;
    margin-top: -15px;
    max-width: 56px;
}

/* Footer hint */
.sh-auth-hint {
    text-align: center;
    font-size: .87rem;
    color: #6f8791;
    margin-top: 1.1rem;
}
.sh-auth-hint a { color: #1d7d97; font-weight: 700; }

/* Address autocomplete */
.sh-address-wrap { position: relative; }

#address-suggestions {
    border-radius: 10px;
    border: 1.5px solid #c7d7dc;
    box-shadow: 0 6px 20px rgba(0,0,0,.09);
    overflow: hidden;
}

#address-suggestions .list-group-item {
    font-size: .87rem;
    padding: .5rem .85rem;
    cursor: pointer;
    border-left: none;
    border-right: none;
}

#address-suggestions .list-group-item:hover {
    background: #e9f1f3;
    color: #1d7d97;
}

/* Alert overrides */
.sh-auth-body .alert { border-radius: 10px; font-size: .9rem; }

/* ─── Browse / listing cards ─────────────────────────────────── */

.product-item,
.listing-card {
    border-radius: 16px !important;
    overflow: hidden;
    box-shadow: 0 3px 14px rgba(0,0,0,.07);
    transition: transform .18s, box-shadow .18s;
}

.product-item:hover,
.listing-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,83,180,.14);
}

/* ─── Badges ─────────────────────────────────────────────────── */

.badge {
    border-radius: 8px !important;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
}

/* ─── Pagination ─────────────────────────────────────────────── */

.page-item .page-link {
    border-radius: 8px !important;
    margin: 0 2px;
    border: 1.5px solid #c7d7dc;
    color: #1d7d97;
    font-weight: 700;
}

.page-item.active .page-link {
    background: #1d7d97;
    border-color: #1d7d97;
}

/* ─── Alerts ─────────────────────────────────────────────────── */

.alert {
    border-radius: 12px !important;
    border: none;
    font-weight: 500;
}

/* ─── Modals ─────────────────────────────────────────────────── */

.modal-content {
    border-radius: 18px !important;
    border: none;
    box-shadow: 0 12px 40px rgba(0,0,0,.15);
}

.modal-header {
    border-radius: 18px 18px 0 0 !important;
    border-bottom: 1.5px solid #dce6ea;
    background: #1d7d97;
    color: #fff;
}

.modal-header .modal-title { font-family: 'Nunito', sans-serif; font-weight: 900; color: #fff; }
.modal-header .close { color: #fff; opacity: .8; }
.modal-header .close:hover { opacity: 1; }

.modal-footer {
    border-radius: 0 0 18px 18px !important;
    border-top: 1.5px solid #eef2fb;
}

/* ─── Tables ─────────────────────────────────────────────────── */

.table thead th {
    background: #e9f1f3;
    color: #47515a;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
    border-top: none;
    font-size: .82rem;
    letter-spacing: .04em;
    text-transform: uppercase;
}

/* ─── Dropdowns ──────────────────────────────────────────────── */

.dropdown-menu {
    border-radius: 14px !important;
    border: 1.5px solid #dce6ea;
    box-shadow: 0 8px 28px rgba(0,0,0,.1);
    padding: .5rem;
}

.dropdown-item {
    border-radius: 8px !important;
    font-weight: 600;
    padding: .45rem .85rem;
}

.dropdown-item:hover {
    background: #e9f1f3;
    color: #1d7d97;
}
